{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch LogHunter",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net8.0/win-x64/LogHunter.exe",
      "args": ["--web"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false,
      "preLaunchTask": "dotnet: build"
    }
  ]
}
