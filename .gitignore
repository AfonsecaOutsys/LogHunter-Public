############################################################
# LogHunter - ignore local data + generated artifacts
############################################################

# --- Runtime folders (tool workspace data) ---
/output/
/ALB/
/IIS/
/PlatformLogs/
/platformlogs/   # keep both, just in case casing differs on some machines

# --- Logs / data files (don't share) ---
*.log
*.log.gz
*.csv
*.xlsx
*.xls
*.har
*.zip
*.7z

# If you really want to ignore all .txt, keep this.
# Otherwise, comment it out so docs can be committed.
*.txt

# --- Build outputs ---
/bin/
/obj/
/src/
**/bin/
**/obj/
artifacts/
publish/

# --- IDE / user files ---
/.vs/
**/.vs/
/.idea/
/.vscode/
/.claude/
*.suo
*.user
*.userosscache
*.sln.docstates

# --- Code-signing certificates (private keys) ---
certs/*.pfx
certs/*.p12

# --- OS junk ---
.DS_Store
Thumbs.db